@page "/movies"
@using Practice1Blazor.Models
@using Practice1Blazor.Services
@inject UserStateService UserState
@inject ApiRequestService ApiRequestService
@inject NavigationManager Nav

<PageTitle>Фильмы</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Фильмы</h1>
        <p class="page-subtitle">Список всех фильмов</p>
    </div>

    @if (UserState.IsAdmin)
    {
        <button class="btn btn-success" @onclick="GoAddMovie">
            Добавить фильм
        </button>
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (movies == null)
{
    <div class="glass-panel hero-box">
        <p class="empty-text">Загрузка...</p>
    </div>
}
else
{
    <div class="app-card mb-4">
        <div class="card-body">

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="app-label">Поиск по названию</label>
                    <input class="form-control" placeholder="Введите название фильма" @bind="searchText" />
                </div>

                <div class="col-12 col-md-4">
                    <label class="app-label">Фильтр по жанру</label>
                    <select class="form-select" @bind="selectedGenre">
                        <option value="">Все жанры</option>
                        @foreach (var genre in genres_names)
                        {
                            <option value="@genre">@genre</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="app-label">Сортировка</label>
                    <select class="form-select" @bind="sortOption">
                        <option value="title">По названию</option>
                        <option value="rating">По рейтингу</option>
                        <option value="date">По дате выхода</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (FilteredMovies.Count == 0)
    {
        <div class="glass-panel hero-box">
            <p class="empty-text">Ничего не найдено.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var movie in FilteredMovies)
            {
                <div class="col-12 col-md-6 col-xl-4" @key="movie.id_movie">
                    <div class="app-card h-100">
                        <div class="card-body d-flex flex-column">
                            <div style="height:320px; margin-bottom:16px; overflow:hidden; border-radius:16px;">
                                <FallbackImage Src="@movie.image_url"
                                               Alt="@movie.title"
                                               Style="width:100%; height:100%; object-fit:cover;" />
                            </div>

                            <h5 class="section-title mb-2">@movie.title</h5>

                            <div class="mb-2">
                                <span class="stat-badge me-2">@movie.name_genre</span>
                                <span class="stat-badge">⭐ @movie.rating</span>
                            </div>

                            <p class="page-subtitle mb-2">
                                Дата выхода: @movie.release_date.ToString("dd.MM.yyyy")
                            </p>

                            <p style="color:#dbe4ff;">
                                @GetShortDescription(movie.description)
                            </p>

                            <div class="mt-auto d-flex gap-2 flex-wrap">
                                <button class="btn btn-primary btn-sm" @onclick="() => GoDetails(movie.id_movie)">
                                    Подробнее
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}





@code {
    private List<MovieDto>? movies;
    private List<GenreDto>? genres;
    private string? errorMessage;

    private string searchText = string.Empty;
    private string selectedGenre = string.Empty;
    private string sortOption = "title";

    private List<string> genres_names = new();


    protected override async Task OnInitializedAsync()
    {
        await LoadMoviesAndGenres();
    }

    private async Task LoadMoviesAndGenres()
    {
        errorMessage = null;

        var result_movies = await ApiRequestService.GetMoviesListAsync();

        if (result_movies == null || !result_movies.status)
        {
            errorMessage = "Ошибка получения фильмов";
            return;
        }
        movies = result_movies.movies ?? new List<MovieDto>();

        var result_genres = await ApiRequestService.GetGenreListAsync();

        if (result_genres == null || !result_genres.status)
        {
            errorMessage = "Ошибка получения жанров";
            return;
        }
        genres = result_genres.genres ?? new List<GenreDto>();
        genres_names = genres.Select(x => x.name).ToList();
    }

    private void GoAddMovie(MouseEventArgs args)
    {
        Nav.NavigateTo("/add-movie");
    }

    private List<MovieDto> FilteredMovies
    {
        get
        {
            var result = movies ?? new List<MovieDto>();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                result = result.Where(x => x.title.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
            }

            if (!string.IsNullOrWhiteSpace(selectedGenre))
            {
                result = result.Where(x => x.name_genre == selectedGenre).ToList();
            }

            result = sortOption switch
            {
                "rating" => result.OrderByDescending(x => x.rating).ToList(),
                "date" => result.OrderByDescending(x => x.release_date).ToList(),
                _ => result.OrderBy(x => x.title).ToList()
            };

            return result;
        }
    }

    private string GetShortDescription(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
            return "Описание отсутствует";

        if (description.Length <= 50)
            return description;

        return description.Substring(0, 50) + "...";
    }

    private void GoDetails(int id)
    {
        Nav.NavigateTo($"/movie/{id}");
    }


}