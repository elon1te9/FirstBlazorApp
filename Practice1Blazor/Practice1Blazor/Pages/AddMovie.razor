@page "/add-movie"
@using Practice1Blazor.Models
@using Practice1Blazor.Requests
@using Practice1Blazor.Services
@inject Practice1Blazor.Services.ApiRequestService ApiRequestService
@inject Practice1Blazor.Services.UserStateService UserState
@inject NavigationManager Nav

<PageTitle>Добавить фильм</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Добавить фильм</h1>
        <p class="page-subtitle">Добвление нового фильма на сайт</p>
    </div>
</div>

    <div class="center-card-wrap">
        <div class="app-card">
            <div class="card-body">
            @if (!string.IsNullOrEmpty(errorMessage))
                {
                <div class="alert alert-danger">@errorMessage</div>
                }

            @if (!string.IsNullOrEmpty(okMessage))
                {
                <div class="alert alert-success">@okMessage</div>
                }

                <div class="mb-3">
                    <label class="app-label">Название</label>
                    <input class="form-control" @bind="model.title" placeholder="Введите название фильма" />
                </div>

                <div class="mb-3">
                    <label class="app-label">Описание</label>
                    <textarea class="form-control" rows="4" @bind="model.description" placeholder="Введите описание"></textarea>
                </div>

                <div class="mb-3">
                    <label class="app-label">Жанр</label>
                    <select class="form-select" @bind="selectedGenre">
                    @foreach (var genre in genres_names)
                        {
                        <option value="@genre">@genre</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="app-label">Дата выхода</label>
                    <input class="form-control" type="date" @bind="model.release_date" />
                </div>

                <div class="mb-3">
                    <label class="app-label">Рейтинг</label>
                    <input class="form-control" type="number" step="0.1" @bind="model.rating" />
                </div>

                <div class="mb-3">
                    <label class="app-label">Ссылка на постер</label>
                    <input class="form-control" @bind="model.image_url" placeholder="https://..." />
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-success" @onclick="CreateMovie">Добавить</button>
                    <button class="btn btn-outline-secondary" @onclick="Back">Назад</button>
                </div>
            </div>
        </div>
    </div>

@code {
    private CreateMovieModel model = new();
    private string? errorMessage;
    private string? okMessage;
    private string? selectedGenre;

    private List<GenreDto>? genres;
    private List<string> genres_names = new();
    protected override async Task OnInitializedAsync()
    {
        await LoadGenres();
    }

    private async Task LoadGenres()
    {
        errorMessage = null;
        var result_genres = await ApiRequestService.GetGenreListAsync();

        if (result_genres == null || !result_genres.status)
        {
            errorMessage = "Ошибка получения жанров";
            return;
        }
        genres = result_genres.genres ?? new List<GenreDto>();
        genres_names = genres.Select(x => x.name).ToList();
    }


    private async Task CreateMovie()
    {
        errorMessage = null;
        okMessage = null;

        if (string.IsNullOrWhiteSpace(model.title))
        {
            errorMessage = "Введите название фильма";
            return;
        }

        if (string.IsNullOrWhiteSpace(model.description))
        {
            errorMessage = "Введите описание фильма";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedGenre))
        {
            errorMessage = "Введите жанр фильма";
            return;
        }

        if (model.rating < 0 || model.rating > 10)
        {
            errorMessage = "Рейтинг должен быть от 0 до 10";
            return;
        }
        var found_genre = genres.FirstOrDefault(x => x.name == selectedGenre);
        model.id_genre = found_genre.id_genre;

        var result = await ApiRequestService.CreateMovieAsync(model);

        if (result == null || !result)
        {
            errorMessage = "Ошибка при добавлении фильма";
            return;
        }

        okMessage = "Фильм успешно добавлен";

        Nav.NavigateTo("/movies");
    }

    private void Back()
    {
        Nav.NavigateTo("/movies");
    }
}