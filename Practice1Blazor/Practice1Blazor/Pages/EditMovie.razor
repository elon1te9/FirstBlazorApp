@page "/edit-movie/{Id:int}"
@using Practice1Blazor.Models
@using Practice1Blazor.Requests
@inject Practice1Blazor.Services.ApiRequestService ApiRequestService
@inject Practice1Blazor.Services.UserStateService UserState
@inject NavigationManager Nav

<PageTitle>Редактировать фильм</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Редактировать фильм</h1>
        <p class="page-subtitle">Изменение информации о фильме</p>
    </div>
</div>

@if (isLoading)
{
    <div class="glass-panel hero-box">
        <p class="empty-text">Загрузка фильма...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (model != null)
{
    <div class="center-card-wrap">
        <div class="app-card">
            <div class="card-body">
                <h5 class="section-title">Форма редактирования</h5>

                <div class="mb-3">
                    <label class="app-label">Название</label>
                    <input class="form-control" @bind="model.title" placeholder="Введите название фильма" />
                </div>

                <div class="mb-3">
                    <label class="app-label">Описание</label>
                    <textarea class="form-control" rows="4" @bind="model.description" placeholder="Введите описание"></textarea>
                </div>

                <div class="mb-3">
                    <label class="app-label">Жанр</label>
                    <select class="form-select" @bind="selectedGenre">
                        @foreach (var genre in genres_names)
                        {
                            <option value="@genre">@genre</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="app-label">Дата выхода</label>
                    <input class="form-control" type="date" @bind="model.release_date" />
                </div>

                <div class="mb-3">
                    <label class="app-label">Рейтинг</label>
                    <input class="form-control" type="number" step="0.1" @bind="model.rating" />
                </div>

                <div class="mb-3">
                    <label class="app-label">Ссылка на постер</label>
                    <input class="form-control" @bind="model.image_url" placeholder="https://..." />
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-primary" @onclick="SaveMovie">Сохранить</button>
                    <button class="btn btn-outline-secondary" @onclick="Back">Назад</button>
                </div>
            </div>
        </div>
    </div>
    
}

@code {

    [Parameter]
    public int Id { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private UpdateMovieModel model = new();

    private string? selectedGenre;
    private List<GenreDto>? genres;
    private List<string> genres_names = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMovie();
    }
    private async Task LoadMovie()
    {
        errorMessage = null;
        isLoading = true;

        var result_movie = await ApiRequestService.GetMovieByIdAsync(Id);

        if (result_movie == null || !result_movie.status || result_movie.movie == null)
        {
            errorMessage = "Ошибка получения данных о фильме";
            isLoading = false;
            return;
        }
        var result_genres = await ApiRequestService.GetGenreListAsync();

        if (result_genres == null || !result_genres.status)
        {
            errorMessage = "Ошибка получения жанров";
            return;
        }
        genres = result_genres.genres ?? new List<GenreDto>();
        genres_names = genres.Select(x => x.name).ToList();

        var movie_genre = genres.FirstOrDefault(x=> x.id_genre == result_movie.movie.id_genre);
        selectedGenre = movie_genre.name;

        model.title = result_movie.movie.title;
        model.description = result_movie.movie.description;
        model.id_genre = result_movie.movie.id_genre;
        model.release_date = result_movie.movie.release_date;
        model.rating = result_movie.movie.rating;
        model.image_url = result_movie.movie.image_url;
        
        isLoading = false;
    }

    private void Back()
    {
        Nav.NavigateTo("/movies");
    }

    private async Task SaveMovie()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.title))
        {
            errorMessage = "Введите название фильма";
            return;
        }

        if (string.IsNullOrWhiteSpace(model.description))
        {
            errorMessage = "Введите описание фильма";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedGenre))
        {
            errorMessage = "Введите жанр фильма";
            return;
        }

        if (model.rating < 0 || model.rating > 10)
        {
            errorMessage = "Рейтинг должен быть от 0 до 10";
            return;
        }
        var found_genre = genres.FirstOrDefault(x => x.name == selectedGenre);
        model.id_genre = found_genre.id_genre;

        var result = await ApiRequestService.UpdateMovieAsync(Id, model);

        if (!result)
        {
            errorMessage = "Ошибка при сохранении фильма";
            return;
        }

        Nav.NavigateTo("/movies");
    }

}

